{{>layouts/header}}

<div id="carouselExampleControls" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="bannerImg/banner1.jfif" class="d-block w-100" alt="...">
        </div>
        <div class="carousel-item">
            <img src="bannerImg/banner2.jfif" class="d-block w-100" alt="...">
        </div>
        <div class="carousel-item">
            <img src="bannerImg/banner3.jfif" class="d-block w-100" alt="...">
        </div>
